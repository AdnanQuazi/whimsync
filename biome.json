{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/*.svg",
      "!node_modules",
      "!.next",
      "!dist",
      "!build"
    ]
  },
  "linter": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  }
}
