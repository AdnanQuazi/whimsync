{
  "name": "whimsync",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --cwd apps/api dev",
    "dev:worker": "bun --cwd apps/worker dev",
    "dev:web": "bun --cwd apps/web dev",
    "test": "bun test",
    "test:api": "bun --cwd apps/api test",
    "db:generate": "bun --cwd packages/db db:generate",
    "db:migrate": "bun packages/db/src/migrate.ts",
    "db:push": "bun --cwd packages/db db:push",
    "db:studio": "bun --cwd packages/db db:studio",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3"
  }
}
