# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL + pgvector)
DATABASE_URL="postgres://whimsync:whimsync_dev_pass@localhost:5432/whimsync"

# Redis / Valkey (BullMQ Queue Engine)
REDIS_URL="redis://localhost:6379"

# S3-Compatible Cold Storage (Local MinIO)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="whimsync"
S3_SECRET_ACCESS_KEY="whimsync_dev_pass"
S3_BUCKET_NAME="whimsync-cold"
S3_FORCE_PATH_STYLE="true"
