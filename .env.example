# --- API Server (`apps/api`) ---
PORT=3001
NODE_ENV=development
JWT_SECRET="dev_super_secret_jwt_key_32_chars_min"
CORS_ORIGINS="http://localhost:3000"

# --- Clerk Authentication Keys (Get these from https://dashboard.clerk.com -> API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_clerk_publishable_key"
CLERK_PUBLISHABLE_KEY="pk_test_your_clerk_publishable_key"
CLERK_SECRET_KEY="sk_test_your_clerk_secret_key"

# --- Database & Queue (`packages/db`, `apps/api`, `apps/worker`) ---
DATABASE_URL="postgres://whimsync:whimsync_dev_pass@localhost:5432/whimsync"
REDIS_URL="redis://localhost:6379"

# --- S3-Compatible Cold Storage (Local MinIO / AWS S3 / Cloudflare R2) ---
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="whimsync"
S3_SECRET_ACCESS_KEY="whimsync_dev_pass"
S3_BUCKET_NAME="whimsync-cold"
S3_FORCE_PATH_STYLE="true"

# --- Worker & LLM Extraction (`apps/worker`) ---
GEMINI_API_KEY="your_gemini_api_key_here"
